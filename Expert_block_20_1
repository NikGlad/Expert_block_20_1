)

(defun er-temp-dcl-path (/ p)
  (setq p (getenv "TEMP"))
  (if (or (null p) (= p ""))
    (setq p ".")
  )
  (if (not (vl-file-directory-p p))
    (setq p ".")
  )
  (strcat p "\\block_20_1_dialog.dcl")
)

(defun er-write-dcl-file (path / f item)
  (setq f (open path "w" "utf8-bom"))
  (if f
    (progn
      (write-line "expert_rays : dialog {" f)
      (write-line "  label = \"Блок 20.1\";" f)
      (write-line "  : column {" f)
      (write-line "    : boxed_column {" f)
      (write-line "      label = \"Выберите параметры\";" f)

      (foreach item *er-items*
        (write-line
          (strcat
            "      : toggle { key = \"" (car item) "\"; label = \"" (cadr item) "\"; }"
          )
          f
        )
      )

      (write-line "    }" f)
      (write-line "    : spacer { height = 1; }" f)
      (write-line "    : row {" f)
      (write-line "      : spacer { width = 1; }" f)
      (write-line "      : button { key = \"accept\"; label = \"OK\"; is_default = true; width = 12; }" f)
      (write-line "      : button { key = \"cancel\"; label = \"Отмена\"; is_cancel = true; width = 12; }" f)
      (write-line "      : spacer { width = 1; }" f)
      (write-line "    }" f)
      (write-line "  }" f)
      (write-line "}" f)
      (close f)
      path
    )
    nil
  )
)

(defun er-capture-dialog (/ item key)
  (setq *er-selected-keys* '())
  (foreach item *er-items*
    (setq key (car item))
    (if (= (get_tile key) "1")
      (setq *er-selected-keys* (append *er-selected-keys* (list key)))
    )
  )
  (princ)
)

(defun er-show-dialog (/ dclfile dclid result sels item)
  (setq sels '())
  (setq *er-selected-keys* '())
  (setq dclfile (er-write-dcl-file (er-temp-dcl-path)))

  (if (null dclfile)
    'ER_DCLERR
    (progn
      (setq dclid (load_dialog dclfile))
      (if (or (null dclid) (< dclid 0))
        (progn
          (if (findfile dclfile) (vl-file-delete dclfile))
          'ER_DCLERR
        )
        (progn
          (if (not (new_dialog "expert_rays" dclid))
            (progn
              (unload_dialog dclid)
              (if (findfile dclfile) (vl-file-delete dclfile))
              'ER_DCLERR
            )
            (progn
              (foreach item *er-items*
                (set_tile (car item) "0")
              )

              (action_tile "accept" "(progn (er-capture-dialog) (done_dialog 1))")
              (action_tile "cancel" "(done_dialog 0)")

              (setq result (start_dialog))

              (unload_dialog dclid)
              (if (findfile dclfile) (vl-file-delete dclfile))

              (cond
                ((= result 0)
                  'ER_CANCEL
                )
                (T
                  (foreach item *er-items*
                    (if (member (car item) *er-selected-keys*)
                      (setq sels (append sels (list item)))
                    )
                  )
                  (if sels sels 'ER_EMPTY)
                )
              )
            )
          )
        )
      )
    )
  )
)

(defun er-get-active-space-object (/ acad doc)
  (setq acad (vlax-get-acad-object))
  (setq doc (vla-get-ActiveDocument acad))
