    (vla-get-PaperSpace doc)
    (vla-get-ModelSpace doc)
  )
)

(defun er-pts->lwpoly-variant (pts / arr idx pt)
  (setq arr (vlax-make-safearray vlax-vbDouble (cons 0 (1- (* 2 (length pts))))))
  (setq idx 0)
  (foreach pt pts
    (vlax-safearray-put-element arr idx (float (car pt)))
    (setq idx (1+ idx))
    (vlax-safearray-put-element arr idx (float (cadr pt)))
    (setq idx (1+ idx))
  )
  (vlax-make-variant arr)
)

(defun er-draw-ray-polyline (p1 p2 / spaceObj var obj r)
  (if (and p1 p2)
    (progn
      (setq spaceObj (er-get-active-space-object))
      (setq var (er-pts->lwpoly-variant (list p1 p2)))
      (setq r (vl-catch-all-apply 'vla-AddLightWeightPolyline (list spaceObj var)))
      (if (vl-catch-all-error-p r)
        nil
        (progn
          (setq obj r)
          (vla-put-Layer obj *er-layer*)
          (vla-put-Color obj *er-ray-color-aci*)
          (vla-put-Linetype obj "ByLayer")
          (vla-put-Lineweight obj -1)
          (vla-Update obj)
          obj
        )
      )
    )
    nil
  )
)

