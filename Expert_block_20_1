)

(defun er-get-bbox-center (ename / bb)
  (setq bb (er-get-bbox ename))
  (if bb
    (list
      (/ (+ (nth 0 bb) (nth 2 bb)) 2.0)
      (/ (+ (nth 1 bb) (nth 3 bb)) 2.0)
      0.0
    )
    nil
  )
)

(defun er-right-edge-point (ename / bb xmin ymin xmax ymax)
  (setq bb (er-get-bbox ename))
  (if bb
    (progn
      (setq xmin (nth 0 bb))
      (setq ymin (nth 1 bb))
      (setq xmax (nth 2 bb))
      (setq ymax (nth 3 bb))
      (list xmax (/ (+ ymin ymax) 2.0) 0.0)
    )
    nil
  )
)

(defun er-closest-point-on-bbox-boundary (pt bb / x y xmin ymin xmax ymax dxl dxr dyb dyt dmin)
  (if (and pt bb)
    (progn
      (setq x    (car pt))
      (setq y    (cadr pt))
      (setq xmin (nth 0 bb))
      (setq ymin (nth 1 bb))
      (setq xmax (nth 2 bb))
      (setq ymax (nth 3 bb))

      (if (or (< x xmin) (> x xmax) (< y ymin) (> y ymax))
        (list
          (er-clamp x xmin xmax)
          (er-clamp y ymin ymax)
          0.0
        )
        (progn
          (setq dxl (abs (- x xmin)))
          (setq dxr (abs (- xmax x)))
          (setq dyb (abs (- y ymin)))
          (setq dyt (abs (- ymax y)))
          (setq dmin (min dxl dxr dyb dyt))
          (cond
            ((= dmin dxl) (list xmin y 0.0))
            ((= dmin dxr) (list xmax y 0.0))
            ((= dmin dyb) (list x ymin 0.0))
            (T            (list x ymax 0.0))
          )
        )
      )
    )
    nil
  )
)

(defun er-first-end-point (pt)
  (if pt
    (list
      (+ (car pt) *er-ray-len*)
      (cadr pt)
      0.0
    )
    nil
  )
)

(defun er-get-block-common-start (en anchor-end / bb)
  (setq bb (er-get-bbox en))
  (if bb
    (if anchor-end
      (er-closest-point-on-bbox-boundary anchor-end bb)
      (er-right-edge-point en)
    )
    nil
  )
)

(defun er-find-source-block (blkname / ss i en nm found)
  (setq found nil)
  (setq ss (ssget "X" (list (cons 0 "INSERT") (cons 8 *er-layer*))))

  (if ss
    (progn
      (setq i 0)
      (while (and (< i (sslength ss)) (null found))
        (setq en (ssname ss i))
        (setq nm (er-get-eff-name en))
        (if (er-str-eq-ci nm blkname)
          (setq found en)
        )
        (setq i (1+ i))
      )
    )
  )
  found
)

