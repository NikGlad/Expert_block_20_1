(defun er-get-bbox (ename / obj r vmin vmax pmin pmax)
  (setq obj (vlax-ename->vla-object ename))
  (setq r (vl-catch-all-apply 'vla-GetBoundingBox (list obj 'vmin 'vmax)))
  (if (vl-catch-all-error-p r)
    nil
    (progn
      (setq pmin (er-anyarray->list vmin))
      (setq pmax (er-anyarray->list vmax))
      (if (and pmin pmax)
        (list (car pmin) (cadr pmin) (car pmax) (cadr pmax))
        nil
      )
    )
