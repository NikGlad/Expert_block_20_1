(defun er-get-cloud-target-point (cloudEn refPt / pt bb)
  (setq pt (er-get-curve-closest-point cloudEn refPt))
  (if pt
    pt
    (progn
      (setq bb (er-get-bbox cloudEn))
      (if (and bb refPt)
        (er-closest-point-on-bbox-boundary refPt bb)
        (er-get-bbox-center cloudEn)
      )
    )
  )
)

(defun er-find-all-yellow-dims (/ ss i en out)
  (setq out '())
  (setq ss (ssget "X" (list (cons 0 "DIMENSION") (cons 8 *er-dim-layer*))))

  (if ss
    (progn
      (setq i 0)
      (while (< i (sslength ss))
        (setq en (ssname ss i))
        (if (er-entity-yellow-p en)
          (setq out (cons en out))
        )
        (setq i (1+ i))
      )
    )
  )

  (reverse out)
)

(defun er-find-all-orange-clouds (/ ss i en typ out)
  (setq out '())
  (setq ss (ssget "X" (list (cons 8 *er-dim-layer*))))

  (if ss
    (progn
      (setq i 0)
      (while (< i (sslength ss))
        (setq en (ssname ss i))
        (setq typ (cdr (assoc 0 (entget en))))
        (if (and
              (er-entity-orange-p en)
              (not (er-str-eq-ci typ "DIMENSION"))
            )
          (setq out (cons en out))
        )
        (setq i (1+ i))
      )
    )
  )

  (reverse out)
)

