(defun er-get-curve-closest-point (ename refPt / obj r pt)
  (setq obj (vlax-ename->vla-object ename))
  (setq r (vl-catch-all-apply 'vlax-curve-getClosestPointTo (list obj refPt)))
  (if (vl-catch-all-error-p r)
