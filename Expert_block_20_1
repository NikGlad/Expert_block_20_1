(defun er-set-entity-color-bylayer (ename / ed old62)
  (if ename
    (progn
      (setq ed (entget ename))
      (setq ed
        (vl-remove-if
          '(lambda (x) (or (= (car x) 420) (= (car x) 430)))
          ed
        )
      )
      (setq old62 (assoc 62 ed))
      (if old62
        (setq ed (subst (cons 62 256) old62 ed))
        (setq ed (append ed (list (cons 62 256))))
      )
      (entmod ed)
      (entupd ename)
      T
    )
    nil
  )
)

