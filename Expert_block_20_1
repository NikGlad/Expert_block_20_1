(defun er-process-dim-rule (en anchor-end threshold / dims dimEn dimVal startPt stdRes obj createdCount skippedCount newAnchor foundAbove)
  (setq createdCount 0)
  (setq skippedCount 0)
  (setq newAnchor anchor-end)
  (setq foundAbove nil)

  (setq startPt (er-get-block-common-start en anchor-end))
  (setq dims (er-find-all-yellow-dims))

  (if startPt
    (progn
      (prompt (strcat "\n  Общая точка выхода лучей блока: " (er-pt->str startPt)))

      (if dims
        (progn
          (prompt (strcat "\n  Найдено жёлтых размеров: " (itoa (length dims))))

          (setq stdRes (er-build-standard-ray startPt anchor-end))
          (if stdRes
            (progn
              (setq createdCount (1+ createdCount))
              (if (null newAnchor)
                (setq newAnchor (cadr stdRes))
              )
              (prompt "\n  Стандартный луч построен.")
            )
            (progn
              (setq skippedCount (1+ skippedCount))
              (prompt "\n  ОШИБКА: стандартный луч не создан.")
            )
          )

          (foreach dimEn dims
            (setq dimVal (er-get-dim-measurement dimEn))
            (prompt (strcat "\n  Размер: " (rtos dimVal 2 2) " мм"))

            (if (> dimVal threshold)
              (progn
                (setq foundAbove T)
                (setq obj (er-build-dim-ray startPt dimEn))
                (if obj
                  (progn
                    (setq createdCount (1+ createdCount))
                    (er-mark-entity-for-post-layer dimEn)
                    (prompt "\n  Дополнительный луч к размеру построен.")
                  )
                  (progn
                    (setq skippedCount (1+ skippedCount))
                    (prompt "\n  ОШИБКА: луч к размеру не создан.")
                  )
                )
              )
            )
          )

          (if (not foundAbove)
            (prompt
              (strcat
                "\n  Размеров больше "
                (rtos threshold 2 2)
                " мм не найдено. Дополнительные лучи к размерам не строятся."
              )
            )
          )
        )
        (progn
          (prompt "\n  Жёлтые размеры в слое \"экспертиза обмеры\" не найдены. Строится только стандартный луч.")
          (setq stdRes (er-build-standard-ray startPt anchor-end))
          (if stdRes
            (progn
              (setq createdCount (1+ createdCount))
              (if (null newAnchor)
                (setq newAnchor (cadr stdRes))
              )
              (prompt "\n  Стандартный луч построен.")
            )
            (progn
              (setq skippedCount (1+ skippedCount))
              (prompt "\n  ОШИБКА: стандартный луч не создан.")
            )
          )
        )
      )
    )
    (progn
      (setq skippedCount (1+ skippedCount))
      (prompt "\n  ОШИБКА: не удалось определить общую точку выхода лучей блока.")
    )
  )

  (list createdCount skippedCount newAnchor)
)

(defun er-process-cloud-rule (en anchor-end / clouds cloudEn obj createdCount skippedCount startPt)
  (setq createdCount 0)
  (setq skippedCount 0)
  (setq startPt (er-get-block-common-start en anchor-end))
  (setq clouds (er-find-all-orange-clouds))

  (if startPt
    (progn
      (prompt (strcat "\n  Общая точка выхода лучей блока: " (er-pt->str startPt)))

      (if clouds
        (progn
          (prompt (strcat "\n  Найдено оранжевых пометочных облаков: " (itoa (length clouds))))
          (foreach cloudEn clouds
            (setq obj (er-build-cloud-ray startPt cloudEn))
            (if obj
              (progn
                (setq createdCount (1+ createdCount))
                (er-mark-entity-for-post-layer cloudEn)
                (prompt "\n  Луч к облаку построен.")
              )
              (progn
                (setq skippedCount (1+ skippedCount))
                (prompt "\n  ОШИБКА: луч к облаку не создан.")
              )
            )
          )
        )
        (setq skippedCount (1+ skippedCount))
      )
    )
    (progn
      (setq skippedCount (1+ skippedCount))
      (prompt "\n  ОШИБКА: не удалось определить общую точку выхода лучей блока.")
    )
  )

  (list createdCount skippedCount)
)

(defun c:BLOCK_20_1 (/ sels anchor-end item key label blkref blklist blkname rule threshold en startPt stdRes created skipped res cloudRes movedCnt)
  (setq sels (er-show-dialog))

  (cond
    ((eq sels 'ER_DCLERR)
      (alert "Ошибка создания или загрузки диалога DCL.")
    )

    ((eq sels 'ER_CANCEL)
      (prompt "\nОтменено.")
    )

    ((eq sels 'ER_EMPTY)
      (alert "Не выбран ни один пункт.")
    )

    ((not (er-layer-exists-p *er-layer*))
      (alert (strcat "Слой [" *er-layer* "] не найден."))
    )

    (T
      (setq anchor-end nil)
      (setq created 0)
      (setq skipped 0)
      (setq *er-post-layer-handles* nil)

      (prompt (strcat "\nВыбрано пунктов: " (itoa (length sels))))

      (foreach item sels
        (setq key       (nth 0 item))
        (setq label     (nth 1 item))
        (setq blkref    (nth 2 item))
        (setq rule      (nth 3 item))
        (setq threshold (nth 4 item))
        (setq blklist   (er-normalize-blocks blkref))

        (prompt (strcat "\nПункт: " label))

        (foreach blkname blklist
          (prompt (strcat "\n  Обработка блока=" blkname))

          (setq en (er-find-source-block blkname))

          (if en
            (cond
              ((= rule "STD")
                (setq startPt (er-get-block-common-start en anchor-end))
                (if startPt
                  (progn
                    (prompt (strcat "\n  Общая точка выхода лучей блока: " (er-pt->str startPt)))
                    (setq stdRes (er-build-standard-ray startPt anchor-end))
                    (if stdRes
                      (progn
                        (setq created (1+ created))
                        (if (null anchor-end)
                          (setq anchor-end (cadr stdRes))
                        )
                        (prompt "\n  Луч построен.")
                      )
                      (progn
                        (setq skipped (1+ skipped))
                        (prompt "\n  ОШИБКА: стандартный луч не создан.")
                      )
                    )
                  )
                  (progn
                    (setq skipped (1+ skipped))
                    (prompt "\n  ОШИБКА: не удалось определить общую точку выхода лучей блока.")
                  )
                )
              )

              ((= rule "DIM_GT")
                (setq res (er-process-dim-rule en anchor-end threshold))
                (setq created (+ created (nth 0 res)))
                (setq skipped (+ skipped (nth 1 res)))
                (setq anchor-end (nth 2 res))
              )

              ((= rule "CLOUD_ORANGE")
                (setq cloudRes (er-process-cloud-rule en anchor-end))
                (setq created (+ created (nth 0 cloudRes)))
                (setq skipped (+ skipped (nth 1 cloudRes)))
                (if (= (nth 0 cloudRes) 0)
                  (prompt "\n  Оранжевые пометочные облака не найдены.")
                )
              )

              (T
                (setq skipped (1+ skipped))
                (prompt "\n  ОШИБКА: неизвестное правило обработки пункта.")
              )
            )

            (progn
              (setq skipped (1+ skipped))
              (prompt
                (strcat
                  "\n  Блок ["
                  blkname
                  "] в слое ["
                  *er-layer*
                  "] не найден."
                )
              )
            )
          )
        )
      )

      (setq movedCnt (er-apply-post-layer-handles))
      (if (> movedCnt 0)
        (prompt
          (strcat
            "\nПеренесено в слой \"экспертиза\" и переведено в цвет по слою объектов: "
            (itoa movedCnt)
          )
        )
      )

      (prompt
        (strcat
          "\nГотово. Построено лучей: "
          (itoa created)
          (if (> skipped 0)
            (strcat ". Пропущено операций: " (itoa skipped))
            ""
          )
        )
      )
    )
  )

  (princ)
)

(princ "\nКоманда загружена: BLOCK_20_1")
(princ)
