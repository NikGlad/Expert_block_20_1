(defun er-layer-exists-p (lay)
  (not (null (tblsearch "LAYER" lay)))
)

(defun er-str-eq-ci (a b)
  (= (strcase (if a a "")) (strcase (if b b "")))
)

(defun er-clamp (v a b)
  (max a (min b v))
)

(defun er-pt->str (pt)
  (if (and pt (listp pt))
    (strcat "(" (rtos (car pt) 2 2) ", " (rtos (cadr pt) 2 2) ")")
    "(nil)"
  )
)

(defun er-anyarray->list (x / r)
  (setq r (vl-catch-all-apply 'vlax-variant-value (list x)))
  (if (vl-catch-all-error-p r)
    (setq r x)
  )
  (setq r (vl-catch-all-apply 'vlax-safearray->list (list r)))
  (if (vl-catch-all-error-p r)
    nil
    r
  )
)

(defun er-normalize-blocks (blkref)
